# PostgreSQL password (default: holodos — change in production!)
POSTGRES_PASSWORD=holodos

# Allowed CORS origins (comma-separated)
# Example for production: http://192.168.1.100:8080,https://holodos.example.com
HOLODOS_CORS_ALLOWED_ORIGINS=http://localhost:*

# Google Tasks OAuth2 (optional, leave empty to disable)
GOOGLE_TASKS_CLIENT_ID=
GOOGLE_TASKS_CLIENT_SECRET=
GOOGLE_TASKS_REDIRECT_URI=
